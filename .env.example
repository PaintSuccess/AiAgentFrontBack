# Environment Variables for Vercel Backend
# Set these in Vercel Dashboard → Settings → Environment Variables

# Shopify Admin API (get from Settings → Apps → Develop apps → "Paint Access AI Backend")
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_token_here

# ElevenLabs
ELEVENLABS_API_KEY=sk_your_elevenlabs_key_here
ELEVENLABS_AGENT_ID=agent_your_agent_id_here

# Auth token for protecting endpoints (used in ElevenLabs server tool headers)
API_SECRET_TOKEN=generate_a_random_64_char_string_here

# Twilio
TWILIO_ACCOUNT_SID=AC_your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_MOBILE_NUMBER=+614_your_sms_capable_twilio_mobile_number_here
TWILIO_SYDNEY_NUMBER=+612_your_voice_capable_sydney_number_here
ELEVENLABS_PHONE_NUMBER_ID_MOBILE=phnum_your_mobile_number_id_here
ELEVENLABS_PHONE_NUMBER_ID_SYDNEY=phnum_your_sydney_number_id_here

# Trade notifications
TRADE_NOTIFICATION_EMAIL=Trade@paintaccess.com.au
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=Paint Access AI

# ElevenLabs post-call transcript webhook (optional signature secret)
ELEVENLABS_WEBHOOK_SECRET=

# Environment Variables for Vercel Backend
# Set these in Vercel Dashboard → Settings → Environment Variables

# Shopify Admin API (get from Settings → Apps → Develop apps → "Paint Access AI Backend")
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_token_here
SHOPIFY_ADMIN_API_VERSION=2026-04
SHOPIFY_APP_SCOPES=read_products,read_inventory,read_orders,write_orders,read_assigned_fulfillment_orders,write_assigned_fulfillment_orders,read_merchant_managed_fulfillment_orders,write_merchant_managed_fulfillment_orders,read_third_party_fulfillment_orders,write_third_party_fulfillment_orders,read_fulfillments,write_fulfillments,read_customers,write_customers,read_draft_orders,write_draft_orders
SHOPIFY_OAUTH_DEPLOY_HOOK_URL=
SHOPIFY_OAUTH_VERCEL_TARGETS=production

# PaintAccess Operations MCP / ChatGPT custom app
SHOPIFY_MCP_TOKEN=generate_a_random_64_char_string_here
MCP_OAUTH_TOKEN_SECRET=generate_a_random_64_char_string_here
MCP_OAUTH_PIN=optional_authorization_pin_for_chatgpt_linking
MCP_OAUTH_AUTO_APPROVE=false
PUBLIC_BASE_URL=https://ai-agent-front-back.vercel.app

# Google Workspace backend authorization for MCP Gmail/Drive tools
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_WORKSPACE_EMAIL=
GOOGLE_OAUTH_ADMIN_PIN=
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_OAUTH_SCOPES=
GOOGLE_OAUTH_DEPLOY_HOOK_URL=
GOOGLE_OAUTH_VERCEL_TARGETS=production

# Optional: lets Google/Shopify OAuth callbacks write refreshed tokens directly to Vercel.
# Without these, callback pages show the token for manual Vercel entry.
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID_OR_NAME=
VERCEL_TEAM_ID=
VERCEL_TEAM_SLUG=
VERCEL_ENV_TARGETS=production
VERCEL_DEPLOY_HOOK_URL=

# ElevenLabs
ELEVENLABS_API_KEY=sk_your_elevenlabs_key_here
ELEVENLABS_AGENT_ID=agent_your_agent_id_here

# Auth token for protecting endpoints (used in ElevenLabs server tool headers)
API_SECRET_TOKEN=generate_a_random_64_char_string_here

# Twilio
TWILIO_ACCOUNT_SID=AC_your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_MOBILE_NUMBER=+614_your_sms_capable_twilio_mobile_number_here
TWILIO_SYDNEY_NUMBER=+612_your_voice_capable_sydney_number_here
TWILIO_WHATSAPP_NUMBER=+614_your_approved_whatsapp_sender_here
TWILIO_MESSAGING_SERVICE_SID=
WHATSAPP_TEMPLATE_SUPPORT_FOLLOWUP=HX_your_support_followup_content_sid
WHATSAPP_TEMPLATE_QUOTE_READY=HX_your_quote_ready_content_sid
WHATSAPP_TEMPLATE_ORDER_ENQUIRY_UPDATE=HX_your_order_enquiry_update_content_sid
ELEVENLABS_PHONE_NUMBER_ID_MOBILE=phnum_your_mobile_number_id_here
ELEVENLABS_PHONE_NUMBER_ID_SYDNEY=phnum_your_sydney_number_id_here

# WhatsApp
# Use twilio for the first production phase after creating the WhatsApp Sender in Twilio.
# Use meta only if switching to direct Meta Cloud API later.
WHATSAPP_PROVIDER=twilio
META_GRAPH_VERSION=v23.0
META_WHATSAPP_VERIFY_TOKEN=generate_a_random_webhook_verify_token_here
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_APP_SECRET=

# Trade notifications
TRADE_NOTIFICATION_EMAIL=Trade@paintaccess.com.au
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=Paint Access AI

# ElevenLabs post-call transcript webhook (optional signature secret)
ELEVENLABS_WEBHOOK_SECRET=

# ElevenLabs inbound Twilio personalization webhook.
# Configure this as an Authorization Bearer token or x-paintaccess-webhook-token
# header in ElevenLabs. If unset, the endpoint falls back to API_SECRET_TOKEN.
ELEVENLABS_TWILIO_PERSONALIZATION_TOKEN=

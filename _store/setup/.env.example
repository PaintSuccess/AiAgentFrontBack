# ============================================================
# Paint Access AI Support — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- ElevenLabs ---
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: override voice (default uses "Rachel" — 21m00Tcm4TlvDq8ikWAM)
# Browse voices at: https://elevenlabs.io/voice-library
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Twilio ---
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+61XXXXXXXXX

# --- Shopify ---
# Store admin URL slug (from https://admin.shopify.com/store/{this-part})
SHOPIFY_STORE_SLUG=zgmzge-0d

# --- Generated (filled automatically by scripts) ---
# ELEVENLABS_AGENT_ID=
# ELEVENLABS_PHONE_NUMBER_ID=

<div class="top-bar">
  <style>
    #shopify-section-{{ section.id }} .top-bar__phone {
      margin-left: auto;
      flex-shrink: 0;
    }

    #shopify-section-{{ section.id }} .top-bar__phone-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: #ffffff;
      font-weight: 700;
      line-height: 1;
      text-decoration: none;
      white-space: nowrap;
    }

    #shopify-section-{{ section.id }} .top-bar__phone-link svg {
      width: 17px;
      height: 17px;
      color: #ff5a1f;
      flex: 0 0 auto;
    }

    @media (max-width: 767px) {
      #shopify-section-{{ section.id }} .top-bar__phone {
        display: none;
      }
    }
  </style>
  <div class="container">
    <div class="top-bar__inner">
      {% comment %}
        <div class="top-bar__phone">
            <a href="tel:{{ section.settings.phone }}" class="top-bar__phone-link">{{ section.settings.phone }}</a>
        </div>
      {% endcomment %}

      {%- if section.settings.related_navigation -%}
        {% assign topBarMav = section.settings.related_navigation %}
        <nav class="top-bar__nav">
          <ul class="top-bar__nav-list">
            {%- for link in linklists[topBarMav].links -%}
              <li class="top-bar__nav-item">
                <a
                  {% if link.handle == 'find-a-tradie' %}
                    target="_blank"
                  {% endif %}
                  class="top-bar__nav-link"
                  data-handle="{{ link.handle }}"
                  href="{{ link.url }}"
                >
                  {{- link.title -}}
                </a>

                {% if link.links.size > 0 %}
                  <ul class="top-bar__dropdown">
                    {% for subLink in link.links %}
                      <li class="top-bar__dropdown-item {% if subLink.links.size > 0 %}top-bar__dropdown-item_second-lvl{% endif %}">
                        <a class="top-bar__dropdown-link" href="{{ subLink.url }}">
                          {{ subLink.title }}
                        </a>
                        {% if subLink.links.size > 0 %}
                          {% render 'icons', name: 'arrow-right' -%}
                        {%- endif %}
                        {% if subLink.links.size > 0 %}
                          <ul class="top-bar__dropdown top-bar__dropdown_third-lvl">
                            {% for subSubLink in subLink.links %}
                              <li class="top-bar__dropdown-item">
                                <a href="{{ subSubLink.url }}" class="top-bar__dropdown-link">{{ subSubLink.title }}</a>
                              </li>
                            {% endfor %}
                          </ul>
                        {% endif %}
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </li>
            {%- endfor -%}
          </ul>
        </nav>
      {%- endif -%}

      <div class="top-bar__phone">
        <a href="tel:+61258385959" class="top-bar__phone-link" aria-label="Call PaintAccess at 02 5838 5959">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M19.23 15.26l-2.54-.29a1.99 1.99 0 0 0-1.64.57l-1.84 1.84a15.045 15.045 0 0 1-6.59-6.59l1.85-1.85c.43-.43.64-1.03.57-1.64l-.29-2.52a2.001 2.001 0 0 0-1.99-1.77H5.03c-1.13 0-2.07.94-2 2.07.53 8.54 7.36 15.36 15.89 15.89 1.13.07 2.07-.87 2.07-2v-1.73c.01-1.01-.75-1.86-1.76-1.98z"/>
          </svg>
          02 5838 5959
        </a>
      </div>

      {% comment %}
        <div class="top-bar__reviews">
          <div class="elfsight-sapp-25d78348-fd76-4fe9-8589-ac319dc6fcdc top-bar__reviews-widget"></div>
        </div>
      {% endcomment %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Top Bar",
  "settings": [
    {
      "type": "text",
      "id": "phone",
      "label": "Phone"
    },
    {
      "type": "link_list",
      "id": "related_navigation",
      "label": "Related Navigation"
    }
  ]
}
{% endschema %}

{%- comment -%}
  Paint Access — Support Widget
  Floating contact launcher with vertical action panel + callback form.

  Public support widget.
{%- endcomment -%}

<script>
  (function () {
    var customerEmail = "{% if customer %}{{ customer.email | escape }}{% endif %}";

    // ---- Configuration ----------------------------------------------------
    var CFG = {
      phone:          '+61258385959',
      phoneDisplay:   '02 5838 5959',
      email:          'trade@paintaccess.com.au',
      whatsapp:       '61485077888',
      whatsappText:   'Hi Paint Access, I need help from the WhatsApp support chat.',
      callbackApi:    'https://ai-agent-front-back.vercel.app/api/callback',
      smsApi:         'https://ai-agent-front-back.vercel.app/api/twilio/sms-send',
      elevenAgentId:  'agent_1001kn99pk1xefprh4gb665f6j3p',
      customerFirstName: "{% if customer %}{{ customer.first_name | escape }}{% endif %}",
      customerName:   "{% if customer %}{{ customer.first_name | escape }} {{ customer.last_name | escape }}{% endif %}",
      customerEmail:  customerEmail,
      customerId:     "{% if customer %}{{ customer.id }}{% endif %}",
      customerPhone:  "{% if customer and customer.phone %}{{ customer.phone | escape }}{% endif %}",
      customerTags:   "{% if customer %}{{ customer.tags | join: ', ' | escape }}{% endif %}",
      customerOrders: "{% if customer and customer.orders_count > 0 %}{% for order in customer.orders limit:3 %}{{ order.name | escape }} placed {{ order.created_at | date: '%d %b %Y' }}{% if order.financial_status_label %}, payment {{ order.financial_status_label | escape }}{% endif %}{% if order.fulfillment_status_label %}, fulfillment {{ order.fulfillment_status_label | escape }}{% endif %}{% unless forloop.last %}; {% endunless %}{% endfor %}{% endif %}"
    };

    // ---- Styles -----------------------------------------------------------
    // Ring sizes: button is 56px; ring SVG is 76px and centered with -10px
    // offsets. Inner/outer radii keep the two arcs on separate tracks.
    var css = ''
      + '.pa-sw-root{position:fixed;right:20px;bottom:100px;z-index:2147483600;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;}'
      + '.pa-sw-root *{box-sizing:border-box;}'
      // Launcher (closed state)
      + '.pa-sw-launcher{width:60px;height:60px;border-radius:50%;background:#FF6128;color:#fff;border:none;cursor:pointer;box-shadow:0 8px 22px rgba(0,0,0,0.24);display:flex;align-items:center;justify-content:center;position:relative;transition:transform .2s ease,box-shadow .2s ease;}'
      + '.pa-sw-launcher:hover{transform:scale(1.05);box-shadow:0 10px 26px rgba(0,0,0,0.28);}'
      + '.pa-sw-launcher svg{width:30px;height:30px;}'
      + '.pa-sw-launcher::before,.pa-sw-launcher::after{content:"";position:absolute;inset:0;border-radius:50%;border:2px solid #FF6128;animation:pa-sw-pulse 2.4s infinite;pointer-events:none;}'
      + '.pa-sw-launcher::after{animation-delay:1.2s;}'
      + '@keyframes pa-sw-pulse{0%{transform:scale(1);opacity:.7;}80%,100%{transform:scale(1.7);opacity:0;}}'
      + '.pa-sw-root[data-open="1"] .pa-sw-launcher{display:none;}'
      // Panel — transparent background, just a vertical stack of buttons
      + '.pa-sw-panel{display:none;background:transparent;box-shadow:none;padding:0;flex-direction:column;align-items:center;gap:18px;}'
      + '.pa-sw-root[data-open="1"] .pa-sw-panel{display:flex;animation:pa-sw-fold-in .25s ease both;}'
      + '@keyframes pa-sw-fold-in{from{opacity:0;transform:translateY(10px) scale(.92);}to{opacity:1;transform:none;}}'
      // Row wraps button + ring + tooltip
      + '.pa-sw-row{position:relative;width:56px;height:56px;display:flex;align-items:center;justify-content:center;}'
      // Action buttons
      + '.pa-sw-action{width:56px;height:56px;border-radius:50%;border:2px solid transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#fff;box-shadow:0 6px 16px rgba(0,0,0,0.2);text-decoration:none;position:relative;z-index:1;transition:transform .2s ease,box-shadow .2s ease,background-color .2s ease,color .2s ease;}'
      + '.pa-sw-row:hover .pa-sw-action{transform:translateY(-1px);box-shadow:0 9px 22px rgba(0,0,0,0.25);}'
      + '.pa-sw-action svg{width:24px;height:24px;}'
      + '.pa-sw-action.ai svg,.pa-sw-action.call svg,.pa-sw-action.sms svg{width:60px;height:60px;}'
      + '.pa-sw-action.ai{background:#FF6128;}'
      + '.pa-sw-action.call{background:#1F8E4D;}'
      + '.pa-sw-action.email{background:#30343B;}'
      + '.pa-sw-action.sms{background:#FFFFFF;color:#FF6128;border-color:#FF6128;}'
      + '.pa-sw-action.whatsapp{background:linear-gradient(180deg,#4AF26B 0%,#09C743 100%);color:#fff;border:0;overflow:hidden;background-clip:border-box;}'
      + '.pa-sw-action.whatsapp svg{color:#fff;fill:#fff;}'
      + '.pa-sw-row.whatsapp:hover .pa-sw-action.whatsapp{background:linear-gradient(180deg,#5DFA7A 0%,#00B93A 100%);color:#fff;box-shadow:0 9px 22px rgba(9,199,67,.34);}'
      + '.pa-sw-action.close{background:#FFFFFF;color:#3A2A2F;border-color:rgba(221,214,208,.8);box-shadow:0 5px 14px rgba(0,0,0,0.16);}'
      + '.pa-sw-action.close svg{width:20px;height:20px;}'
      // Email remains hidden; WhatsApp is live through the Twilio WhatsApp sender.
      + '.pa-sw-row.email{display:none!important;}'
      // Hover ring — two incomplete arcs spin in opposite directions.
      + '.pa-sw-ring{position:absolute;top:-10px;left:-10px;width:76px;height:76px;pointer-events:none;overflow:visible;z-index:0;}'
      + '.pa-sw-ring circle{fill:none;stroke:currentColor;stroke-width:2.5;stroke-linecap:round;opacity:0;transform-box:view-box;transform-origin:center;transition:opacity .18s ease;}'
      + '.pa-sw-ring .pa-sw-ring-a{stroke-dasharray:86 109;}'
      + '.pa-sw-ring .pa-sw-ring-b{stroke-dasharray:98 122;}'
      + '.pa-sw-ring .pa-sw-ring-a{transform:rotate(-80deg);}'
      + '.pa-sw-ring .pa-sw-ring-b{stroke-width:2;stroke-dashoffset:95;transform:rotate(100deg);opacity:0;}'
      + '.pa-sw-row:hover .pa-sw-ring circle{opacity:1;}'
      + '.pa-sw-row:hover .pa-sw-ring-a{animation:pa-sw-spin-cw 1.15s linear infinite;}'
      + '.pa-sw-row:hover .pa-sw-ring-b{animation:pa-sw-spin-ccw 1.4s linear infinite;}'
      + '@keyframes pa-sw-spin-cw{to{transform:rotate(280deg);}}'
      + '@keyframes pa-sw-spin-ccw{to{transform:rotate(-260deg);}}'
      + '.pa-sw-row.ai{color:#FF6128;}'
      + '.pa-sw-row.call{color:#3A2A2F;}'
      + '.pa-sw-row.email{color:#30343B;}'
      + '.pa-sw-row.sms{color:#FF6128;}'
      + '.pa-sw-row.whatsapp{color:#09C743;}'
      + '.pa-sw-row.close{color:rgba(221,214,208,.95);}'
      // Tooltip
      + '.pa-sw-tooltip{position:absolute;right:82px;top:50%;transform:translateY(-50%);background:#3A2A2F;color:#fff;font-size:13px;padding:7px 11px;border-radius:6px;white-space:nowrap;opacity:0;pointer-events:none;transition:opacity .18s,transform .18s;box-shadow:0 4px 14px rgba(0,0,0,0.18);}'
      + '.pa-sw-tooltip::after{content:"";position:absolute;left:100%;top:50%;transform:translateY(-50%);border:6px solid transparent;border-left-color:#3A2A2F;}'
      + '.pa-sw-row:hover .pa-sw-tooltip{opacity:1;}'
      // Callback form
      + '.pa-sw-form{display:none;position:absolute;right:0;bottom:0;width:344px;max-width:calc(100vw - 32px);background:#fff;border:1px solid rgba(25,25,25,.1);border-radius:8px;box-shadow:0 16px 44px rgba(0,0,0,0.24);padding:22px 20px 20px;}'
      + '.pa-sw-form::before{content:"";position:absolute;left:0;right:0;top:0;height:4px;background:#FF6128;border-radius:8px 8px 0 0;}'
      + '.pa-sw-root[data-form="1"] .pa-sw-panel{display:none;}'
      + '.pa-sw-root[data-form="1"] .pa-sw-form{display:block;}'
      + '.pa-sw-form-head{display:flex;justify-content:space-between;align-items:flex-start;gap:12px;margin-bottom:16px;padding-bottom:13px;border-bottom:1px solid #EFEFEF;}'
      + '.pa-sw-form-head h3{margin:0;font-size:18px;line-height:1.2;color:#3A2A2F;font-weight:700;}'
      + '.pa-sw-form-head p{margin:6px 0 0;font-size:13px;color:#575757;line-height:1.35;}'
      + '.pa-sw-form-close{background:#F7F7F7;border:1px solid #E7E7E7;cursor:pointer;color:#555;padding:7px;line-height:0;border-radius:50%;flex-shrink:0;transition:background .16s ease,color .16s ease,border-color .16s ease;}'
      + '.pa-sw-form-close:hover{background:#3A2A2F;border-color:#3A2A2F;color:#fff;}'
      + '.pa-sw-form-close svg{width:18px;height:18px;}'
      + '.pa-sw-field{display:block;margin-bottom:11px;}'
      + '.pa-sw-field label{display:block;font-size:12px;color:#2F2F2F;margin-bottom:5px;font-weight:700;}'
      + '.pa-sw-field input,.pa-sw-field textarea,.pa-sw-field select{width:100%;min-height:42px;padding:10px 12px;border:1px solid #D7D7D7;border-radius:6px;font:inherit;font-size:14px;background:#FBFBFB;color:#191919;box-shadow:inset 0 1px 0 rgba(255,255,255,.65);transition:border-color .16s ease,box-shadow .16s ease,background .16s ease;}'
      + '.pa-sw-field input:focus,.pa-sw-field textarea:focus,.pa-sw-field select:focus{outline:none;background:#fff;border-color:#FF6128;box-shadow:0 0 0 3px rgba(255,97,40,.16);}'
      + '.pa-sw-field small{display:block;margin-top:5px;font-size:12px;color:#6A6A6A;line-height:1.35;}'
      + '.pa-sw-field textarea{min-height:70px;resize:vertical;}'
      + '.pa-sw-submit{width:100%;background:#FF6128;color:#fff;border:none;border-radius:6px;padding:12px 14px;font:inherit;font-size:15px;font-weight:700;cursor:pointer;margin-top:4px;box-shadow:0 8px 18px rgba(255,97,40,.26);transition:background .18s ease,transform .18s ease,box-shadow .18s ease;}'
      + '.pa-sw-submit:hover{background:#E8501E;transform:translateY(-1px);box-shadow:0 10px 22px rgba(255,97,40,.3);}'
      + '.pa-sw-submit:disabled{opacity:.6;cursor:not-allowed;}'
      + '.pa-sw-status{font-size:13px;margin-top:10px;padding:9px 10px;border-radius:6px;display:none;line-height:1.35;}'
      + '.pa-sw-status.error{display:block;background:#FFF4E8;color:#8A3A12;border:1px solid #FFD2A9;}'
      + '.pa-sw-status.success{display:block;background:#EDF8F0;color:#1D6B3A;border:1px solid #CDEDD7;}'
      + '.pa-sw-disclaimer{font-size:11px;color:#666;line-height:1.35;margin:10px 0 0;}'
      + '.pa-sw-eleven-close{position:fixed;width:36px;height:36px;border-radius:50%;border:2px solid #e0e0e0;background:#fff;color:#444;box-shadow:0 2px 8px rgba(0,0,0,0.18);cursor:pointer;z-index:2147483700;display:none;align-items:center;justify-content:center;}'
      + '.pa-sw-eleven-close svg{width:16px;height:16px;}'
      + '.pa-sw-eleven-close:hover{background:#f3f3f3;}'
      // Voice → chat product results overlay (rendered when the agent
      // calls the display_products_in_chat client tool). Positioned to
      // the LEFT of the ElevenLabs widget panel so it sits beside the
      // call view instead of covering it.
      + '.pa-sw-results{position:fixed;z-index:2147483650;width:340px;max-width:calc(100vw - 32px);max-height:70vh;overflow-y:auto;background:#fff;border-radius:14px;box-shadow:0 12px 36px rgba(0,0,0,0.28);padding:14px 14px 18px;display:none;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;}'
      + '.pa-sw-results[data-open="1"]{display:block;animation:pa-sw-fold-in .22s ease both;}'
      + '.pa-sw-results-head{display:flex;align-items:center;justify-content:space-between;margin:0 0 10px;}'
      + '.pa-sw-results-head h4{margin:0;font-size:14px;font-weight:600;color:#1a1a1a;}'
      + '.pa-sw-results-close{background:none;border:none;cursor:pointer;color:#888;padding:4px;border-radius:6px;line-height:0;}'
      + '.pa-sw-results-close:hover{background:#f3f3f3;color:#222;}'
      + '.pa-sw-results-close svg{width:16px;height:16px;}'
      + '.pa-sw-results-intro{margin:0 0 10px;font-size:13px;color:#444;line-height:1.45;}'
      + '.pa-sw-card{display:block;border:1px solid #ececec;border-radius:10px;padding:10px 12px;margin-bottom:8px;text-decoration:none;color:#1a1a1a;transition:border-color .15s,background .15s;}'
      + '.pa-sw-card:hover{border-color:#FF6128;background:#fafafa;}'
      + '.pa-sw-card-name{font-size:14px;font-weight:600;color:#1a1a1a;margin:0 0 3px;line-height:1.3;}'
      + '.pa-sw-card-meta{display:flex;align-items:center;gap:8px;flex-wrap:wrap;font-size:12px;color:#666;margin:0;}'
      + '.pa-sw-card-price{color:#FF6128;font-weight:600;}'
      + '.pa-sw-badge{display:inline-block;font-size:11px;font-weight:600;border-radius:4px;padding:1px 6px;line-height:1.6;}'
      + '.pa-sw-badge--green{background:#d4edda;color:#1a6130;}'
      + '.pa-sw-badge--amber{background:#fff3cd;color:#7a5700;}'
      + '.pa-sw-card-note{font-size:12px;color:#555;margin:4px 0 0;line-height:1.4;}'
      // Mobile responsiveness:
      //   - Tablet/phone (≤768px): hide hover tooltips (touch has no hover),
      //     keep the panel close to the corner, give Eleven's close button a
      //     proper 44px touch target.
      //   - Phone (≤480px): shrink launcher + action buttons slightly, cap
      //     callback form height so it never overflows, scroll if needed.
      // NOTE: do NOT use /* block comments */ between `+ 'str'` lines — JS
      // parses `+ /* */ + 'next'` as a unary plus and yields NaN.
      + '@media(max-width:768px){'
      +   '.pa-sw-results{left:12px!important;right:12px!important;width:auto;bottom:12px!important;top:auto!important;max-height:55vh;}'
      +   '.pa-sw-panel{gap:14px;}'
      +   '.pa-sw-tooltip{display:none!important;}'
      +   '.pa-sw-eleven-close{width:44px;height:44px;}'
      +   '.pa-sw-eleven-close svg{width:18px;height:18px;}'
      + '}'
      + '@media(max-width:480px){'
      +   '.pa-sw-root{right:12px;}'
      +   '.pa-sw-form{width:calc(100vw - 32px);max-height:calc(100dvh - 160px);overflow-y:auto;padding:18px;}'
      +   '.pa-sw-form-head h3{font-size:16px;}'
      +   '.pa-sw-launcher{width:56px;height:56px;}'
      +   '.pa-sw-launcher svg{width:28px;height:28px;}'
      +   '.pa-sw-action,.pa-sw-row{width:52px;height:52px;}'
      +   '.pa-sw-action svg{width:22px;height:22px;}'
      +   '.pa-sw-action.ai svg,.pa-sw-action.call svg,.pa-sw-action.sms svg{width:56px;height:56px;}'
      +   '.pa-sw-ring{top:-10px;left:-10px;width:72px;height:72px;}'
      + '}';

    var style = document.createElement('style');
    style.textContent = css;
    document.head.appendChild(style);

    // ---- SVG icons (Material / Heroicons style) ---------------------------
    var ICON = {
      // Solid phone handset
      phone:    '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.23 15.26l-2.54-.29a1.99 1.99 0 0 0-1.64.57l-1.84 1.84a15.045 15.045 0 0 1-6.59-6.59l1.85-1.85c.43-.43.64-1.03.57-1.64l-.29-2.52a2.001 2.001 0 0 0-1.99-1.77H5.03c-1.13 0-2.07.94-2 2.07.53 8.54 7.36 15.36 15.89 15.89 1.13.07 2.07-.87 2.07-2v-1.73c.01-1.01-.75-1.86-1.76-1.98z"/></svg>',
      // AI chat icon
      aiChat:   '<svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M19.5 10.5H29C34 10.5 38 14.2 38 18.8C38 23.4 34 27.1 29 27.1H20.2L12 31.8L14 24.9C12.2 23.4 11 21.3 11 18.8C11 14.2 15 10.5 19.5 10.5Z" fill="white"/><path d="M25 22.5H33C38 22.5 42 26.2 42 30.9C42 33.4 40.8 35.7 38.9 37.2L40.8 42L34.8 38.8C34.2 38.9 33.6 39 33 39H25C20 39 16 35.3 16 30.9C16 26.2 20 22.5 25 22.5Z" fill="white"/><text x="24" y="23.5" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-size="13" font-weight="700" fill="#FF6128">AI</text><circle cx="24.7" cy="31" r="1.85" fill="#FF6128"/><circle cx="30.2" cy="31" r="1.85" fill="#FF6128"/><circle cx="35.7" cy="31" r="1.85" fill="#FF6128"/></svg>',
      // Phone icon
      mic:      '<svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><g transform="translate(24 24) scale(1.07) translate(-24 -24)"><path d="M28 14C32.4 14.7 35.3 17.6 36 22" stroke="white" stroke-width="3.4" stroke-linecap="round"/><path d="M27.3 19C29.3 19.4 30.6 20.7 31 22.7" stroke="white" stroke-width="3.4" stroke-linecap="round"/><path d="M17.7 13.3C17.1 12.4 15.8 12.3 15 13.1L11.9 16.2C11.1 17 10.9 18.2 11.4 19.2C14.7 26.1 20.2 31.5 27.1 34.8C28.1 35.3 29.3 35.1 30.1 34.3L33.2 31.2C34 30.4 33.9 29.1 33 28.5L28.7 25.4C27.9 24.8 26.8 24.9 26.1 25.6L24.8 26.9C22.6 25.6 20.7 23.7 19.4 21.5L20.7 20.2C21.4 19.5 21.5 18.4 20.9 17.6L17.7 13.3Z" fill="white"/></g></svg>',
      // Envelope
      mail:     '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zm0 4.24l-8 4.99-8-4.99V6l8 5 8-5v2.24z"/></svg>',
      // SMS icon
      sms: '<svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M17 13H31C37.1 13 41.5 16.8 41.5 22C41.5 27.2 37.1 31 31 31H18.6L9 37V28.9C7.4 27.2 6.5 24.9 6.5 22C6.5 16.8 10.9 13 17 13Z" fill="currentColor"/><text x="24" y="25.5" text-anchor="middle" font-family="Arial, Helvetica, sans-serif" font-size="10.5" font-weight="700" fill="white">SMS</text></svg>',
      // WhatsApp Business glyph extracted from the provided source SVG.
      whatsapp: '<svg viewBox="600 100 265 265" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path fill-rule="evenodd" d="M804.42,105.4h22.54v30.87h30.87v22.54h-30.87v30.87h-22.54v-30.87h-30.87v-22.54h30.87v-30.87h0ZM733.21,124.51c10.97,0,21.56,1.65,31.53,4.71v-22.68c-10.31-2.66-21.12-4.08-32.26-4.08-71.03,0-128.61,57.58-128.61,128.61,0,22.49,5.77,43.63,15.92,62.02l-18.19,69.53,69.91-18.29c18.15,9.79,38.91,15.35,60.98,15.35,71.03,0,128.61-57.58,128.61-128.61,0-10.55-1.28-20.81-3.68-30.62h-21.56c3.03,9.92,4.66,20.45,4.66,31.36,0,59.26-48.04,107.3-107.3,107.3-22.58,0-43.52-6.98-60.8-18.89l-25.66,6.72-12.82,3.35,7.58-28.96h0s2.56-9.79,2.56-9.79c-11.46-17.07-18.15-37.62-18.15-59.73,0-59.26,48.04-107.3,107.3-107.3h0ZM698.7,175.12c-2.17-5.23-3.83-5.4-7.18-5.56-1.15-.06-2.4-.11-3.76-.11-4.32,0-8.79,1.27-11.49,4.03-3.28,3.36-11.48,11.22-11.48,27.36s11.76,31.75,13.4,33.94c1.64,2.19,22.93,35.8,56.06,49.53,25.86,10.71,33.53,9.75,39.43,8.46,8.58-1.87,19.36-8.19,22.09-15.85,2.73-7.66,2.73-14.23,1.91-15.6-.82-1.37-3.01-2.19-6.29-3.83-3.28-1.64-19.42-9.58-22.42-10.67-3-1.09-5.79-.76-8.1,2.44-3.2,4.42-6.26,8.96-8.81,11.66-2,2.11-5.21,2.41-7.97,1.23-3.63-1.55-13.86-5.11-26.39-16.29-9.75-8.69-16.34-19.44-18.25-22.72-1.91-3.28-.17-5.24,1.31-7.03,1.68-2.04,3.23-3.5,4.87-5.41,1.65-1.92,2.56-2.94,3.65-5.13,1.09-2.19.35-4.45-.46-6.09-.82-1.65-7.39-17.78-10.12-24.36Z"/></svg>',
      // X close
      close:    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>',
      // Chat bubble for launcher
      bubble:   '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 2H4a2 2 0 0 0-2 2v18l4-4h14a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2zM7 9h10v2H7V9zm0 3h7v2H7v-2zm0-6h10v2H7V6z"/></svg>'
    };

    // SVG ring snippet reused for each row
    var RING = '<svg class="pa-sw-ring" viewBox="0 0 76 76"><circle class="pa-sw-ring-a" cx="38" cy="38" r="31"/><circle class="pa-sw-ring-b" cx="38" cy="38" r="35"/></svg>';

    function row(cls, btnHtml, tooltip) {
      return '<div class="pa-sw-row ' + cls + '">' + RING + btnHtml + '<span class="pa-sw-tooltip">' + tooltip + '</span></div>';
    }

    function whatsappUrl() {
      return 'https://wa.me/' + CFG.whatsapp + '?text=' + encodeURIComponent(CFG.whatsappText);
    }

    // ---- Root markup ------------------------------------------------------
    var root = document.createElement('div');
    root.className = 'pa-sw-root';
    root.innerHTML = ''
      + '<button class="pa-sw-launcher" type="button" aria-label="Open support">' + ICON.bubble + '</button>'
      + '<div class="pa-sw-panel" role="dialog" aria-label="Support options">'
      +   row('ai',       '<button class="pa-sw-action ai" data-action="ai-chat" type="button" aria-label="AI chat">' + ICON.aiChat + '</button>',                                                            'AI Chat')
      +   row('call',     '<button class="pa-sw-action call" data-action="ai-call" type="button" aria-label="Voice call with AI">' + ICON.mic + '</button>',                                                  'Voice call (AI)')
      +   row('whatsapp', '<a class="pa-sw-action whatsapp" target="_blank" rel="noopener" href="' + whatsappUrl() + '" aria-label="WhatsApp support chat">' + ICON.whatsapp + '</a>',                         'WhatsApp')
      +   row('email',    '<a class="pa-sw-action email" href="mailto:' + CFG.email + '" aria-label="Email us">' + ICON.mail + '</a>',                                                                         'Email us')
      +   row('sms',      '<button class="pa-sw-action sms" data-action="sms" type="button" aria-label="Send us an SMS">' + ICON.sms + '</button>',                                                       'Send us an SMS')
      +   row('close',    '<button class="pa-sw-action close" data-action="close" type="button" aria-label="Close">' + ICON.close + '</button>',                                                               'Close')
      + '</div>'
      + '<form class="pa-sw-form" novalidate>'
      +   '<div class="pa-sw-form-head"><div><h3>Send us an SMS</h3><p>Fill in your details and we\'ll text you from our Paint Access SMS number.</p></div><button type="button" class="pa-sw-form-close" data-action="form-close" aria-label="Close form">' + ICON.close + '</button></div>'
      +   '<div class="pa-sw-field"><label>First name</label><input name="first_name" type="text" autocomplete="given-name" required></div>'
      +   '<div class="pa-sw-field"><label>Last name</label><input name="last_name" type="text" autocomplete="family-name" required></div>'
      +   '<div class="pa-sw-field"><label>Email</label><input name="email" type="email" autocomplete="email" required></div>'
      +   '<div class="pa-sw-field"><label>Your phone number (mobile)</label><input name="phone" type="tel" inputmode="numeric" autocomplete="tel-national" placeholder="04XX XXX XXX" pattern="04[0-9 ]{8,12}" required><small>Enter Australian mobile number starting with 04</small></div>'
      +   '<div class="pa-sw-field"><label>Message (optional)</label><textarea name="message" rows="2" placeholder="How can we help you?"></textarea></div>'
      +   '<button type="submit" class="pa-sw-submit">Send SMS</button>'
      +   '<div class="pa-sw-status" role="status" aria-live="polite"></div>'
      +   '<p class="pa-sw-disclaimer">By submitting, you agree Paint Access may text or call you about this request. Message and data rates may apply. Reply STOP to opt out.</p>'
      + '</form>';
    document.body.appendChild(root);

    // ---- Interactions -----------------------------------------------------
    function openPanel()  { root.dataset.open = '1'; root.dataset.form = ''; }
    function closeAll()   { root.dataset.open = '';  root.dataset.form = ''; }
    function openForm()   { root.dataset.form = '1'; }
    function closeForm()  { root.dataset.form = ''; root.dataset.open = '1'; }

    root.querySelector('.pa-sw-launcher').addEventListener('click', function () {
      openPanel();
      // Pre-load the ElevenLabs script while the user reads the panel options.
      // Mobile browsers grant the audio autoplay permission for ~1 s after a
      // user tap. If the script isn't already cached the download takes several
      // seconds, blowing past that window and silencing the agent's greeting.
      // Starting the download here (on launcher tap) gives it a head-start so
      // the script is ready — or nearly so — when the user picks Voice/Chat.
      ensureElevenScript(function () {});
    });
    root.addEventListener('click', function (e) {
      var t = e.target.closest('[data-action]');
      if (!t) return;
      var a = t.dataset.action;
      if (a === 'close')           closeAll();
      else if (a === 'sms')        openForm();
      else if (a === 'form-close') closeForm();
      else if (a === 'ai-chat')    openEleven('chat');
      else if (a === 'ai-call')    openEleven('voice');
    });

    // ---- SMS form submit ------------------------------------------------
    // Sends through the backend so desktop users receive an SMS from the
    // Paint Access Twilio number instead of relying on a local SMS app.
    var form = root.querySelector('.pa-sw-form');
    var status = form.querySelector('.pa-sw-status');
    var phoneInput = form.elements.phone;
    var submitBtn = form.querySelector('.pa-sw-submit');

    function normaliseAustralianMobile(value) {
      var digits = String(value || '').replace(/\D/g, '');
      if (digits.indexOf('6104') === 0) digits = '04' + digits.slice(4);
      else if (digits.indexOf('614') === 0) digits = '04' + digits.slice(3);
      else if (digits.indexOf('4') === 0 && digits.length === 9) digits = '0' + digits;
      return digits;
    }

    function formatAustralianMobile(value) {
      var digits = normaliseAustralianMobile(value).slice(0, 10);
      if (digits.length <= 4) return digits;
      if (digits.length <= 7) return digits.slice(0, 4) + ' ' + digits.slice(4);
      return digits.slice(0, 4) + ' ' + digits.slice(4, 7) + ' ' + digits.slice(7);
    }

    phoneInput.addEventListener('input', function () {
      phoneInput.value = formatAustralianMobile(phoneInput.value);
    });

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      status.className = 'pa-sw-status';
      status.textContent = '';

      var firstName = form.elements.first_name.value.trim();
      var lastName  = form.elements.last_name.value.trim();
      var email     = form.elements.email.value.trim();
      var phone     = formatAustralianMobile(form.elements.phone.value);
      var message   = form.elements.message.value.trim();

      if (!firstName || !lastName || !email || !phone) {
        status.className = 'pa-sw-status error';
        status.textContent = 'Please fill in all required fields.';
        return;
      }

      if (!/^04\d{8}$/.test(normaliseAustralianMobile(phone))) {
        status.className = 'pa-sw-status error';
        status.textContent = 'Please enter an Australian mobile number starting with 04.';
        return;
      }

      form.elements.phone.value = phone;

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      status.className = 'pa-sw-status success';
      status.textContent = 'Sending SMS...';

      fetch(CFG.smsApi, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          first_name: firstName,
          last_name: lastName,
          email: email,
          phone: normaliseAustralianMobile(phone),
          message: message
        })
      })
        .then(function (res) {
          return res.json().catch(function () { return {}; }).then(function (data) {
            if (!res.ok) throw new Error(data.error || 'SMS send failed.');
            return data;
          });
        })
        .then(function (data) {
          status.className = 'pa-sw-status success';
          status.textContent = data.message || 'Thanks! We sent an SMS to your mobile number.';
          form.reset();
          setTimeout(closeAll, 3000);
        })
        .catch(function (err) {
          status.className = 'pa-sw-status error';
          status.textContent = err.message || 'We could not send the SMS. Please try again.';
        })
        .finally(function () {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send SMS';
        });
    });

    // ---- AI widget (ElevenLabs Convai) -----------------------------------
    // Important: we intentionally do NOT touch the widget's shadow DOM here.
    // Previous attempts (hiding launcher, injecting CSS, re-mounting) caused
    // layout jumps and broke the widget's own close button. We just mount the
    // widget once and let it render normally. The agent's *dashboard*
    // modality settings decide voice vs text — that's the supported way.
    //
    //   • Voice call button: sets start-call="true" so a call starts as soon
    //     as the widget initialises.
    //   • Chat button: just opens the widget (no start-call) — the user can
    //     then type. For this to land on the text input directly, set the
    //     agent's Widget → Interface in the ElevenLabs dashboard to
    //     "Voice + text" with Text input toggle ON (or "Text only").
    //
    // The widget has its own visible close/minimise control, so we don't add
    // an extra one and we don't suppress theirs.
    var elevenScriptLoaded = false;
    var elevenEl = null;
    var elevenMode = null;    // 'chat' | 'voice' | null
    var elevenOpened = false; // panel currently shown
    var elevenOpenToken = 0;  // invalidates stale async opens when switching modes

    // Overlay X close — the widget's own minimise control isn't always
    // visible (especially when start-call auto-opens the call view).
    var elevenCloseBtn = document.createElement('button');
    elevenCloseBtn.type = 'button';
    elevenCloseBtn.className = 'pa-sw-eleven-close';
    elevenCloseBtn.setAttribute('aria-label', 'Close');
    elevenCloseBtn.innerHTML = ICON.close;
    elevenCloseBtn.addEventListener('click', function () { closeEleven(); });
    document.body.appendChild(elevenCloseBtn);

    // ---- Voice → chat product results overlay ----------------------------
    // Product cards render in two ways:
    //   1. The agent calls the `display_products_in_chat` client tool.
    //   2. Safety net: we observe ElevenLabs WebSocket tool-result events and
    //      render `search_products` results even if the LLM skips the follow-up
    //      client tool. This avoids model-specific tool chaining flakiness.
    var elevenResults = document.createElement('div');
    elevenResults.className = 'pa-sw-results';
    elevenResults.setAttribute('aria-live', 'polite');
    elevenResults.innerHTML =
      '<div class="pa-sw-results-head">'
      + '<h4>Recommended for you</h4>'
      + '<button type="button" class="pa-sw-results-close" aria-label="Hide results">' + ICON.close + '</button>'
      + '</div>'
      + '<p class="pa-sw-results-intro" data-pa-intro></p>'
      + '<div data-pa-cards></div>';
    document.body.appendChild(elevenResults);
    elevenResults.querySelector('.pa-sw-results-close')
      .addEventListener('click', function () { hideResults(); });

    function hideResults() {
      elevenResults.removeAttribute('data-open');
    }
    function escapeHTML(s) {
      return String(s == null ? '' : s)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }
    function safeUrl(u) {
      // Only allow http(s) URLs; everything else becomes #.
      try {
        var p = new URL(u, window.location.origin);
        if (p.protocol === 'http:' || p.protocol === 'https:') return p.href;
      } catch (e) {}
      return '#';
    }
    function positionResults() {
      // Anchor the results panel to the left of the ElevenLabs panel.
      if (!elevenEl || !elevenEl.shadowRoot) return;
      var panel = elevenEl.shadowRoot.querySelector('.sheet');
      if (!panel) return;
      var r = panel.getBoundingClientRect();
      if (!r.width) return;
      // Reset mobile overrides set by CSS for sm screens.
      if (window.innerWidth > 768) {
        elevenResults.style.right = (window.innerWidth - r.left + 12) + 'px';
        elevenResults.style.bottom = Math.max(12, window.innerHeight - r.bottom) + 'px';
        elevenResults.style.top = '';
        elevenResults.style.left = '';
      } else {
        // Let CSS handle mobile.
        elevenResults.style.right = '';
        elevenResults.style.bottom = '';
        elevenResults.style.top = '';
        elevenResults.style.left = '';
      }
    }
    function showResults(payload) {
      if (!elevenResults) { console.error('showResults: elevenResults not ready'); return; }
      var intro = (payload && payload.intro) || '';
      var products = (payload && Array.isArray(payload.products)) ? payload.products : [];
      elevenResults.querySelector('[data-pa-intro]').textContent = intro;
      var cards = products.slice(0, 6).map(function (p) {
        var name  = escapeHTML(p && p.name);
        var url   = safeUrl(p && p.url);
        var price = p && p.price ? escapeHTML(p.price) : '';
        var note  = p && p.note ? escapeHTML(p.note) : '';
        var avail = (p && p.available != null) ? p.available : null;
        // Stock badge: use explicit available field if present; fall back to
        // recognising "In stock" / "unavailable" keywords in the note.
        var badgeHtml = '';
        if (avail === true || (avail == null && note && /in stock/i.test(note))) {
          badgeHtml = '<span class="pa-sw-badge pa-sw-badge--green">In stock</span>';
          if (/in stock/i.test(note)) note = note.replace(/in stock/i, '').trim().replace(/^[,;:]+/, '').trim();
        } else if (avail === false || (avail == null && note && /unavailable|out of stock/i.test(note))) {
          badgeHtml = '<span class="pa-sw-badge pa-sw-badge--amber">Check availability</span>';
          if (/unavailable|out of stock/i.test(note)) note = note.replace(/currently unavailable|unavailable|out of stock/i, '').trim().replace(/^[,;:]+/, '').trim();
        }
        return ''
          + '<a class="pa-sw-card" href="' + url + '" target="_blank" rel="noopener">'
          +   '<p class="pa-sw-card-name">' + name + '</p>'
          +   '<p class="pa-sw-card-meta">'
          +     (price ? '<span class="pa-sw-card-price">' + price + '</span>' : '')
          +     badgeHtml
          +   '</p>'
          +   (note  ? '<p class="pa-sw-card-note">' + note + '</p>' : '')
          + '</a>';
      }).join('');
      elevenResults.querySelector('[data-pa-cards]').innerHTML = cards
        || '<p class="pa-sw-card-note">No matching products.</p>';
      elevenResults.setAttribute('data-open', '1');
      positionResults();
    }

    var productAutoDisplayInstalled = false;
    var lastAutoProductKey = '';
    function installProductAutoDisplayWatcher() {
      if (productAutoDisplayInstalled || typeof window.WebSocket !== 'function') return;
      productAutoDisplayInstalled = true;

      var NativeWebSocket = window.WebSocket;

      function WrappedWebSocket(url, protocols) {
        var ws = protocols !== undefined
          ? new NativeWebSocket(url, protocols)
          : new NativeWebSocket(url);

        try {
          var urlText = String(url && url.url ? url.url : url);
          if (/elevenlabs|convai/i.test(urlText)) {
            ws.addEventListener('message', function (event) {
              try { autoDisplayProductsFromMessage(event.data); }
              catch (e) { console.warn('product auto-display failed:', e); }
            });
          }
        } catch (e) {}

        return ws;
      }

      try {
        Object.setPrototypeOf(WrappedWebSocket, NativeWebSocket);
        WrappedWebSocket.prototype = NativeWebSocket.prototype;
        ['CONNECTING', 'OPEN', 'CLOSING', 'CLOSED'].forEach(function (key) {
          try { WrappedWebSocket[key] = NativeWebSocket[key]; } catch (e) {}
        });
        window.WebSocket = WrappedWebSocket;
      } catch (e) {
        productAutoDisplayInstalled = false;
        window.WebSocket = NativeWebSocket;
      }
    }

    function parseMaybeJSON(value) {
      if (typeof value !== 'string') return value;
      var s = value.trim();
      if (!s || ('{['.indexOf(s.charAt(0)) === -1)) return value;
      try { return JSON.parse(s); } catch (e) { return value; }
    }

    function isProductLike(item) {
      return !!item && typeof item === 'object' && !!(item.url || item.name || item.title);
    }

    function normaliseProducts(products) {
      return products.filter(isProductLike).slice(0, 6).map(function (p) {
        return {
          name: p.name || p.title || '',
          url: p.url || '#',
          price: p.price || '',
          note: p.note || p.product_type || p.vendor || '',
          available: p.available
        };
      }).filter(function (p) { return p.name && p.url && p.url !== '#'; });
    }

    function productKey(products) {
      return products.map(function (p) { return p.url || p.name; }).join('|');
    }

    function autoDisplayProductsFromPayload(payload) {
      var products = normaliseProducts(payload && payload.products || []);
      if (!products.length) return;

      var key = productKey(products);
      if (key && key === lastAutoProductKey) return;
      lastAutoProductKey = key;

      showResults({
        intro: payload.intro || ('Found ' + products.length + ' product' + (products.length === 1 ? ':' : 's:')),
        products: products
      });
    }

    function scanForProductPayloads(value, depth) {
      if (depth > 7 || value == null) return;
      value = parseMaybeJSON(value);

      if (Array.isArray(value)) {
        value.forEach(function (item) { scanForProductPayloads(item, depth + 1); });
        return;
      }

      if (typeof value !== 'object') return;

      if (Array.isArray(value.products)) {
        autoDisplayProductsFromPayload(value);
      }

      Object.keys(value).forEach(function (key) {
        scanForProductPayloads(value[key], depth + 1);
      });
    }

    function autoDisplayProductsFromMessage(raw) {
      var data = parseMaybeJSON(raw);
      if (!data || typeof data !== 'object') return;

      // `agent_tool_response` payloads are the ideal path, but the recursive
      // scan also catches provider shape changes and nested JSON strings.
      scanForProductPayloads(data, 0);
    }

    // ---- Client tools exposed to the ElevenLabs widget --------------------
    // Each tool's name must match the tool definition on the agent
    // (see setup/create-tools.js). The agent dispatches a call, the
    // widget invokes the handler in the browser, and we update the UI.
    var clientTools = {
      display_products_in_chat: function (params) {
        try { showResults(params || {}); } catch (e) { console.error('display_products_in_chat failed:', e); }
        return 'displayed';
      },
      end_conversation: function () {
        // Agent calls this tool when ending the conversation. We schedule the
        // widget close immediately. After 1.5s we also force-end the session
        // in case the built-in end_call doesn't fire in the same response.
        try { scheduleClose(); } catch (e) {}
        setTimeout(function () {
          try {
            if (activeSession && typeof activeSession.isOpen === 'function' && activeSession.isOpen()) {
              activeSession.endSession();
            }
          } catch (e) {}
        }, 1500);
        return 'conversation ending';
      }
    };

    function ensureElevenScript(cb) {
      installProductAutoDisplayWatcher();
      if (window.customElements && customElements.get && customElements.get('elevenlabs-convai')) {
        return cb();
      }
      if (!elevenScriptLoaded) {
        elevenScriptLoaded = true;
        var s = document.createElement('script');
        s.src = 'https://unpkg.com/@elevenlabs/convai-widget-embed';
        s.async = true;
        s.type = 'text/javascript';
        document.body.appendChild(s);
      }
      var tries = 0;
      var i = setInterval(function () {
        tries++;
        if (window.customElements && customElements.get && customElements.get('elevenlabs-convai')) {
          clearInterval(i); cb();
        } else if (tries > 80) { clearInterval(i); cb(); }
      }, 200);
    }

    function mountEleven(mode) {
      callEverStarted = false;
      elevenEl = document.createElement('elevenlabs-convai');
      elevenEl.setAttribute('agent-id', CFG.elevenAgentId);
      if (mode === 'chat') {
        elevenEl.setAttribute('override-text-only', 'true');
        elevenEl.setAttribute('text-input', 'true');
        elevenEl.setAttribute('transcript', 'true');
        elevenEl.setAttribute('use-rtc', 'false');
      }
      elevenEl.setAttribute('dynamic-variables', JSON.stringify({
        channel: 'website_widget',
        conversation_mode: mode || 'chat',
        ui_surface: 'website_widget',
        display_products_available: 'true',
        customer_name:  CFG.customerName || '',
        customer_greeting: CFG.customerFirstName ? ' ' + CFG.customerFirstName : '',
        customer_email: CFG.customerEmail || '',
        customer_id:    CFG.customerId || '',
        customer_phone: CFG.customerPhone || '',
        customer_tags:  CFG.customerTags || '',
        customer_recent_orders: CFG.customerOrders || '',
        customer_context_summary: CFG.customerOrders
          ? 'Logged-in Shopify customer. Recent orders: ' + CFG.customerOrders
          : ''
      }));
      // Register client-side tools BEFORE the widget initialises the call.
      // The widget fires `elevenlabs-convai:call` once per session; we inject
      // our config here.
      //
      // IMPORTANT — widget override list (confirmed from widget source):
      //   onMessage, onDisconnect, onStatusChange, onModeChange,
      //   onCanSendFeedbackChange, onAgentChatResponsePart,
      //   onAgentToolRequest, onAgentToolResponse  ← ALL replaced, injections discarded.
      //
      // SAFE to inject (not overridden):
      //   clientTools, onConversationCreated, onDebug, onConnect,
      //   onAudio, onInterruption, onAgentResponseCorrection
      elevenEl.addEventListener('elevenlabs-convai:call', function (event) {
        callEverStarted = true;
        try {
          if (event && event.detail && event.detail.config) {
            event.detail.config.clientTools = clientTools;

            // Store session reference so end_conversation client tool can
            // call endSession() if end_call doesn't fire in the same turn.
            event.detail.config.onConversationCreated = function (session) {
              activeSession = session;
            };

            // onDebug fires for internal_tentative_agent_response messages.
            // These contain the FULL tentative agent response text as the LLM
            // generates it — including farewell phrases — in voice mode.
            // NOT overridden by the widget's startSession. Belt-and-suspenders
            // signal alongside the end_conversation client tool.
            event.detail.config.onDebug = function (debug) {
              try {
                if (debug && debug.type === 'tentative_agent_response' && debug.response) {
                  if (farewellRe.test(debug.response)) { scheduleClose(); }
                }
              } catch (e) {}
            };
          }
        } catch (e) { console.error('client tools registration failed:', e); }
        // Give the widget 600 ms to render the active-call UI before we start
        // watching, so we don't fire on the pre-call 'New call' button text.
        setTimeout(function () { watchForDisconnect(); }, 600);
      });
      // Voice auto-start is driven by one guarded click in driveWidget().
      // Do not also set start-call="true"; using both can create two calls.
      // Shift the panel left so it clears our FAB launcher button. On mobile
      // the launcher is smaller (52-56px) and tucked into the corner, so we
      // need less overlay padding — otherwise the widget's own panel ends up
      // hanging off the right edge of the screen.
      // --el-overlay-padding shifts the panel left from the right viewport edge.
      // On mobile the shadow CSS already constrains width/position, so keep
      // this small to avoid the panel being pushed off-screen to the left.
      var overlayPad = window.matchMedia('(max-width:768px)').matches ? '0px' : '90px';
      elevenEl.style.setProperty('--el-overlay-padding', overlayPad);
      document.body.appendChild(elevenEl);
      return elevenEl;
    }

    function closeEleven() {
      elevenOpenToken++;
      if (driveWidgetInterval) { clearInterval(driveWidgetInterval); driveWidgetInterval = null; }
      if (disconnectObs) { disconnectObs.disconnect(); disconnectObs = null; }
      if (disconnectPollId) { clearInterval(disconnectPollId); disconnectPollId = null; }
      if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
      endActiveSession();
      callEverStarted = false;
      elevenCloseBtn.style.display = 'none';
      elevenCloseBtn.style.visibility = 'visible';
      stopPositionLoop();
      hideResults();
      elevenOpened = false;
      elevenMode = null;
      shadowStyleInjected = false;
      if (elevenEl && elevenEl.parentNode) elevenEl.parentNode.removeChild(elevenEl);
      elevenEl = null;
    }

    // --- Disconnect detection -----------------------------------------------
    // Three independent signals all call scheduleClose() → 7-second countdown
    // → closeEleven(). Any ONE is sufficient; all three together are reliable.
    //
    // Signal 1 — end_conversation CLIENT TOOL (most reliable):
    //   Agent calls our end_conversation tool on farewell. Browser code runs
    //   immediately: scheduleClose() + force-ends session after 1.5s.
    //   Requires: agent config has end_conversation tool + system prompt.
    //
    // Signal 2 — onDebug tentative_agent_response:
    //   Fires as the LLM generates the response text (before speech ends).
    //   NOT overridden by the widget. Detects farewell phrases in the raw
    //   tentative text the moment they appear.
    //
    // Signal 3 — Shadow-DOM MutationObserver + setInterval polling:
    //   Catches 'ended the conversation' / 'New call' text that the widget
    //   renders after the session fully disconnects (end_call fires or
    //   end_conversation forces endSession()). Polling backup ensures the
    //   observer never misses a mutation.

    var closeTimer = null;        // auto-close countdown
    var disconnectObs = null;     // MutationObserver on shadow root
    var disconnectPollId = null;  // setInterval polling backup
    var callEverStarted = false;  // true once elevenlabs-convai:call fires
    var activeSession = null;     // session ref from onConversationCreated

    // Farewell phrases Jessica uses — checked against onAgentChatResponsePart.
    var farewellRe = /have a great (one|day)\b|happy painting\b|all the best\b|take care\b|bye\b/i;

    function endActiveSession() {
      var session = activeSession;
      activeSession = null;
      try {
        if (session && typeof session.endSession === 'function') {
          session.endSession();
        }
      } catch (e) {}
    }

    function scheduleClose() {
      if (closeTimer) return; // already counting down
      closeTimer = setTimeout(function () {
        closeTimer = null;
        try { closeEleven(); } catch (e) {}
      }, 7000);
    }

    // Check if the shadow DOM shows the post-call disconnect state.
    function checkDisconnected(root) {
      if (!elevenEl || !callEverStarted) return false;
      var text = root.textContent || '';
      return text.indexOf('ended the conversation') !== -1 || text.indexOf('New call') !== -1;
    }

    // Watch shadow DOM for the post-call disconnect state text.
    // Uses both a MutationObserver and a setInterval polling backup.
    function watchForDisconnect() {
      if (!elevenEl || disconnectObs) return;
      // shadowRoot is always available on a custom element once defined.
      // Fall back to the element itself in case it isn't (shouldn't happen).
      var root = elevenEl.shadowRoot || elevenEl;

      // Immediate check: if disconnect already happened within the 600ms delay.
      if (checkDisconnected(root)) { scheduleClose(); return; }

      var obs = new MutationObserver(function () {
        if (checkDisconnected(root)) {
          obs.disconnect(); disconnectObs = null;
          if (disconnectPollId) { clearInterval(disconnectPollId); disconnectPollId = null; }
          scheduleClose();
        }
      });
      obs.observe(root, { childList: true, subtree: true, characterData: true });
      disconnectObs = obs;

      // Polling backup every 750ms — catches mutations the observer might miss
      // (nested shadow DOM redraws, browser quirks with characterData events).
      disconnectPollId = setInterval(function () {
        if (!elevenEl) { clearInterval(disconnectPollId); disconnectPollId = null; return; }
        if (checkDisconnected(root)) {
          obs.disconnect(); disconnectObs = null;
          clearInterval(disconnectPollId); disconnectPollId = null;
          scheduleClose();
        }
      }, 750);
    }

    // Position the close button anchored to the actual panel's top-right.
    // We strictly target ".sheet" (the panel container) — NOT classes that
    // merely contain "sheet" as a substring like "rounded-compact-sheet"
    // (which is the small launcher bubble at the bottom).
    function positionCloseBtn() {
      if (!elevenEl || !elevenEl.shadowRoot) return false;
      var panel = elevenEl.shadowRoot.querySelector('.sheet');
      if (!panel) return false;
      var r = panel.getBoundingClientRect();
      if (!r.width) return false;
      var btnW = elevenCloseBtn.offsetWidth || (window.innerWidth <= 768 ? 44 : 36);
      var half = btnW / 2;
      if (window.innerWidth <= 768) {
        // On mobile the panel top is near the site header — placing the
        // close button above the panel bleeds into the navigation bar.
        // Instead, anchor it INSIDE the panel's top-right corner.
        elevenCloseBtn.style.top   = (r.top + 10) + 'px';
        elevenCloseBtn.style.right = Math.max(4, window.innerWidth - r.right + 10) + 'px';
      } else {
        elevenCloseBtn.style.top   = Math.max(4, r.top - half) + 'px';
        elevenCloseBtn.style.right = Math.max(4, window.innerWidth - r.right - half) + 'px';
      }
      return true;
    }

    // Click the small launcher bubble (collapsed state) to expand the panel.
    function clickLauncherBubble(sr) {
      // The launcher is the small floating bubble. Its container has class
      // "rounded-compact-sheet" and contains a single button (no aria-label).
      var bubble = sr.querySelector('.rounded-compact-sheet button');
      if (bubble) { bubble.click(); return true; }
      return false;
    }

    // Click the in-panel "Start a call" button (voice mode).
    function clickStartCall(sr) {
      var btns = Array.prototype.slice.call(sr.querySelectorAll('button:not([disabled])'));
      for (var b = 0; b < btns.length; b++) {
        var lbl = (btns[b].getAttribute('aria-label') || '').toLowerCase();
        if (lbl === 'start a call' || lbl.indexOf('start a call') !== -1) {
          btns[b].click();
          return true;
        }
      }
      return false;
    }

    // Inject CSS into shadow root to hide Collapse button and "Powered by" footer.
    var shadowStyleInjected = false;
    function injectShadowCSS(sr) {
      if (shadowStyleInjected) return;
      var st = document.createElement('style');
      st.setAttribute('data-pa', '1');
      st.textContent =
        // Hide the Collapse button AND its white circle container
        'button[aria-label="Collapse"],.rounded-compact-sheet{display:none!important;}'
        // Hide the "Powered by ElevenLabs" footer link/text
        + 'a[href*="elevenlabs.io"]{display:none!important;}'
        + 'button[aria-label="Start a call"],button[aria-label*="start a call" i]{background:#1F8E4D!important;background-color:#1F8E4D!important;border-color:#1F8E4D!important;color:#fff!important;}'

        // ---- Mobile compact overrides ----
        // NOTE: the Shopify theme's root font-size is ~7.8px so we MUST use
        // px not rem for sizes that are relative to the design intention.
        //
        // Sheet positioning: the widget anchors .sheet with both top AND bottom
        // so the element stretches to fill the gap. Overriding `bottom` with a
        // larger value shortens the panel from below without touching `top`.
        //
        // .sheet > div:nth-child(3) = orb container (absolute, default 192×192)
        //   > div:first-child       = visual circle (w-48 h-48 = 192px Tailwind)
        // .sheet > div:nth-child(2) > div:first-child = scrollable content (pt-20 = 80px)
        // .sheet > div:nth-child(2) > div:last-child  = sticky input bar
        + '@media(max-width:768px){'
        +   '.sheet{width:calc(100vw - 20px)!important;max-width:calc(100vw - 20px)!important;bottom:185px!important;right:10px!important;}'
        +   '.sheet > div:nth-child(3) > div:first-child{width:130px!important;height:130px!important;}'
        +   '.sheet > div:nth-child(2) > div:first-child{padding-top:36px!important;}'
        +   '.sheet > div:nth-child(2) > div:last-child > div > div{padding-bottom:8px!important;}'
        + '}'
        + '@media(max-width:480px){'
        +   '.sheet{width:calc(100vw - 14px)!important;max-width:calc(100vw - 14px)!important;bottom:180px!important;right:7px!important;}'
        +   '.sheet > div:nth-child(3) > div:first-child{width:110px!important;height:110px!important;}'
        +   '.sheet > div:nth-child(2) > div:first-child{padding-top:28px!important;}'
        + '}';
      sr.appendChild(st);
      shadowStyleInjected = true;
    }

    // Drive the widget open. Voice calls are started by one guarded synthetic
    // click on "Start a call". We intentionally do not also use start-call.
    var driveWidgetInterval = null;
    function driveWidget(el, mode) {
      if (driveWidgetInterval) { clearInterval(driveWidgetInterval); driveWidgetInterval = null; }
      var token = elevenOpenToken;
      var phase = 'launcher'; // launcher → opened
      var voiceStartClicked = false;
      var tries = 0;
      driveWidgetInterval = setInterval(function () {
        tries++;
        if (token !== elevenOpenToken || el !== elevenEl) { clearInterval(driveWidgetInterval); driveWidgetInterval = null; return; }
        if (tries > 80) { clearInterval(driveWidgetInterval); driveWidgetInterval = null; return; } // ~16s
        var sr = el.shadowRoot;
        if (!sr) return;

        if (phase === 'launcher') {
          if (clickLauncherBubble(sr)) phase = 'opening';
        }
        // Once panel exists, position close button and inject CSS.
        var panelExists = positionCloseBtn();
        if (panelExists && phase === 'opening') {
          injectShadowCSS(sr);
          compactSheet();
          phase = 'opened';
        }
        if (phase === 'opened' && mode === 'voice' && !voiceStartClicked) {
          voiceStartClicked = clickStartCall(sr);
          if (!voiceStartClicked) return;
        }
        // Stop polling once chat is open, or once the single voice start click
        // has been sent. The call event itself is tracked separately.
        if (phase === 'opened' && (mode !== 'voice' || voiceStartClicked)) {
          clearInterval(driveWidgetInterval); driveWidgetInterval = null;
        }
      }, 150);
    }

    // Keep the close button glued to the panel as it animates / resizes.
    // Cheap: cancel-on-unmount via interval cleared in closeEleven.
    // Force compact sizing on mobile by setting inline styles on shadow DOM
    // elements every tick — CSS !important alone loses to the widget's own JS
    // on real mobile Safari which continuously resets inline bottom/sizes.
    function compactSheet() {
      if (!elevenEl || !elevenEl.shadowRoot || window.innerWidth > 768) return;
      var sr = elevenEl.shadowRoot;
      var sheet = sr.querySelector('.sheet');
      if (!sheet) return;
      var isSm = window.innerWidth <= 480;
      sheet.style.setProperty('bottom', isSm ? '180px' : '185px', 'important');
      sheet.style.setProperty('top', 'auto', 'important');
      sheet.style.setProperty('max-height', isSm ? 'calc(100dvh - 310px)' : 'calc(100dvh - 310px)', 'important');
      var orb = sheet.children[2] && sheet.children[2].firstElementChild;
      if (orb) {
        var sz = isSm ? '110px' : '130px';
        orb.style.setProperty('width', sz, 'important');
        orb.style.setProperty('height', sz, 'important');
      }
      var ctPad = sheet.children[1] && sheet.children[1].firstElementChild;
      if (ctPad) ctPad.style.setProperty('padding-top', isSm ? '28px' : '36px', 'important');
    }

    var positionInterval = null;
    function startPositionLoop() {
      if (positionInterval) clearInterval(positionInterval);
      positionInterval = setInterval(function () {
        positionCloseBtn();
        compactSheet();
        if (elevenResults.getAttribute('data-open') === '1') positionResults();
      }, 250);
    }
    function stopPositionLoop() {
      if (positionInterval) { clearInterval(positionInterval); positionInterval = null; }
    }

    function openEleven(mode) {
      // Same mode already open: do nothing.
      if (elevenOpened && elevenMode === mode) return;
      // Different mode or first open: tear down and remount.
      if (elevenEl) closeEleven();
      var openToken = ++elevenOpenToken;
      root.dataset.open = '';
      root.dataset.form = '';
      ensureElevenScript(function () {
        if (openToken !== elevenOpenToken) return;
        var el = mountEleven(mode);
        elevenOpened = true;
        elevenMode = mode;
        elevenCloseBtn.style.display = 'flex';
        // Hide the close button until correctly positioned to avoid the
        // jump-from-wrong-spot flicker.
        elevenCloseBtn.style.visibility = 'hidden';
        driveWidget(el, mode);
        // Show close button as soon as it's at the right place.
        var showTries = 0;
        var showIv = setInterval(function () {
          showTries++;
          if (openToken !== elevenOpenToken || el !== elevenEl) { clearInterval(showIv); return; }
          if (showTries > 80) { clearInterval(showIv); return; }
          if (positionCloseBtn()) {
            elevenCloseBtn.style.visibility = 'visible';
            clearInterval(showIv);
            startPositionLoop();
          }
        }, 150);
      });
    }
  })();
</script>

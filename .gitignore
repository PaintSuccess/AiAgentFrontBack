node_modules/
dist/
.vercel/
.env
.env.local
.vercel

# _store/ — non-backend files tracked for history (Shopify theme, setup scripts, KB)
# Exclude secrets and generated artefacts only:
_store/setup/auth.json
_store/setup/.env
_store/setup/.env.local
_store/setup/node_modules/
_store/setup/test-output/
_store/setup/find-pretty.err
_store/setup/find-pretty.log
_store/setup/find-pretty.out
_store/setup/*.err
_store/setup/*.log
.env*.local

# Codex-generated backups & conversation dumps: these contain live auth tokens and
# customer conversation data (flagged by codex review 2026-07-16). This repo is PUBLIC —
# a stray `git add .` would leak them. Ignore everything under .codex/ EXCEPT the tracked
# workflow skill.
/.codex/*
!/.codex/skills/
!/.codex/skills/**

# Claude Code local config (launch.json etc.) — machine-local, not for the repo.
/.claude/

# Stray working-dir artefacts seen at repo root (mirrors the _store/setup ignores above).
/find-pretty.log
/test-output/

# Generated local-only backup for bind-lookup-order-identity.js --revert (holds the tool's
# original schema; regenerated on first --commit, not meant for the repo).
_store/setup/lookup-order-identity-backup.json
_store/setup/voice-stack-backups/

# Any script-generated *-backup*.json under _store/setup (escalate-identity-backup.json,
# kb-backup-<id>.json, …): local revert artifacts, regenerated on demand — never for the
# repo, which is PUBLIC.
_store/setup/*-backup*.json

# Local-only Comms Hub QA harnesses: hit live Supabase/Shopify/Twilio and hardcode the
# test identity (personal email, customer id) — keep out of the public repo.
scripts/test-hub-*.js
